# ============================================================
# TrendPulse Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# Google Analytics 4 (GA4)
# Get from: https://analytics.google.com → Admin → Property → Data Streams
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX

# YouTube Data API v3
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# Used for fetching trending YouTube videos by country
YOUTUBE_API_KEY=your_youtube_api_key_here

# Formspree (contact form)
# Get from: https://formspree.io → Your Forms → Form ID
# Replace REPLACE_WITH_FORMSPREE_ID in contact/page.tsx with this value
FORMSPREE_ID=your_formspree_form_id_here

# Google Search Console (optional, for SEO monitoring)
# GOOGLE_SEARCH_CONSOLE_KEY=your_gsc_key_here

# GitHub Actions (set these in GitHub repository secrets, not here)
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_vercel_org_id
# VERCEL_PROJECT_ID=your_vercel_project_id
